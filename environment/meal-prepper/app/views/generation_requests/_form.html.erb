<%= form_with(model: generation_request) do |form| %>
  <% if generation_request.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(generation_request.errors.count, "error") %> prohibited this generation_request from being saved:</h2>

      <ul>
        <% generation_request.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :user_id, style: "display: block" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.label :prompt, style: "display: block" %>
    <%= form.textarea :prompt %>
  </div>

  <div>
    <%= form.label :raw_response, style: "display: block" %>
    <%= form.textarea :raw_response %>
  </div>

  <div>
    <%= form.label :model_used, style: "display: block" %>
    <%= form.text_field :model_used %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.text_field :status %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
