<%= form_with(model: recipe) do |form| %>
  <% if recipe.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(recipe.errors.count, "error") %> prohibited this recipe from being saved:</h2>

      <ul>
        <% recipe.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :user_id, style: "display: block" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.label :generation_request_id, style: "display: block" %>
    <%= form.text_field :generation_request_id %>
  </div>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.label :servings, style: "display: block" %>
    <%= form.number_field :servings %>
  </div>

  <div>
    <%= form.label :prep_time_minutes, style: "display: block" %>
    <%= form.number_field :prep_time_minutes %>
  </div>

  <div>
    <%= form.label :cook_time_minutes, style: "display: block" %>
    <%= form.number_field :cook_time_minutes %>
  </div>

  <div>
    <%= form.label :instructions, style: "display: block" %>
    <%= form.textarea :instructions %>
  </div>

  <div>
    <%= form.label :is_published, style: "display: block" %>
    <%= form.checkbox :is_published %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
